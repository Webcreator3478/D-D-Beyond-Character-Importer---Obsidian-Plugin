{
  "name": "dndbeyond-importer",
  "version": "1.1.2",
  "description": "Import public D&D Beyond characters as Obsidian notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "dnd",
    "dndbeyond",
    "dungeons-and-dragons"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@eslint/json": "^0.9.0",
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-obsidianmd": "^0.1.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^4.7.4",
    "typescript-eslint": "^8.0.0"
  }
}
