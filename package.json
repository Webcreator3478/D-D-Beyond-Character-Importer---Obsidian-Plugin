{
  "name": "dndbeyond-importer",
  "version": "1.1.0",
  "description": "Import public D&D Beyond characters as Obsidian notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "dnd",
    "dndbeyond",
    "dungeons-and-dragons"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
